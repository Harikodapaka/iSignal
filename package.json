{
  "name": "isignal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@auth/mongodb-adapter": "^3.0.0",
    "@mantine/charts": "^8.3.0",
    "@mantine/core": "^8.3.0",
    "@mantine/dates": "^8.3.0",
    "@mantine/hooks": "^8.3.0",
    "@mantine/notifications": "^8.3.0",
    "@tabler/icons-react": "^3.0.0",
    "@vercel/functions": "^2.0.0",
    "dayjs": "^1.11.0",
    "mongodb": "^6.0.0",
    "mongoose": "^8.0.0",
    "next": "^16.0.0",
    "next-auth": "beta",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^2.15.0",
    "zod": "^3.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "postcss": "^8.0.0",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.0",
    "prettier": "^3.8.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.56.1"
  },
  "overrides": {
    "next-auth": {
      "next": "$next"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
